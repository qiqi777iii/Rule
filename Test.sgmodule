#!name=自定义测速配置 (Testing)
#!desc=用于配置 Surge 的内部测速参数。支持直接在 Surge 界面中点击本模块进行可视化编辑。

// 基础测速链接配置
#!argument=DownloadURL, type=string, default="http://speedtest.macupdate.com/speedtest/100MB.zip", description="download-url: 直连下载测速链接"
#!argument=UploadURL, type=string, default="http://speedtest.macupdate.com/speedtest/100MB.zip", description="upload-url: 直连上传测速链接"

// 代理测速链接配置（留空则默认使用上方直连链接）
#!argument=DownloadURLProxy, type=string, default="", description="download-url-proxy: 代理专用下载测速链接"
#!argument=UploadURLProxy, type=string, default="", description="upload-url-proxy: 代理专用上传测速链接"

// 并发限制（默认为 4）
#!argument=DownloadConcurrency, type=number, default=4, description="download-concurrency: 下载并发数"
#!argument=UploadConcurrency, type=number, default=4, description="upload-concurrency: 上传并发数"

// 时长与大小限制
#!argument=DownloadDurationLimit, type=number, default=10, description="download-duration-limit: 下载测速最大时长（秒）"
#!argument=UploadDurationLimit, type=number, default=10, description="upload-duration-limit: 上传测速最大时长（秒）"
#!argument=UploadSizeLimit, type=string, default="1GB", description="upload-size-limit: 上传数据大小限制"

[Testing]
download-url = {{{DownloadURL}}}
upload-url = {{{UploadURL}}}
download-url-proxy = {{{DownloadURLProxy}}}
upload-url-proxy = {{{UploadURLProxy}}}
download-concurrency = {{{DownloadConcurrency}}}
upload-concurrency = {{{UploadConcurrency}}}
download-duration-limit = {{{DownloadDurationLimit}}}
upload-size-limit = {{{UploadSizeLimit}}}
upload-duration-limit = {{{UploadDurationLimit}}}
