#!name=Network Speed Test
#!desc=网络测速配置模块 - 支持参数自定义
#!system=ios
#!arguments=DOWNLOAD_URL:https://speed.cloudflare.com/__down?bytes=100000000
#!arguments=UPLOAD_URL:https://speed.cloudflare.com/__up
#!arguments=DOWNLOAD_URL_PROXY:
#!arguments=UPLOAD_URL_PROXY:
#!arguments=DOWNLOAD_CONCURRENCY:4
#!arguments=UPLOAD_CONCURRENCY:4
#!arguments=DOWNLOAD_DURATION:10
#!arguments=UPLOAD_SIZE:1073741824
#!arguments=UPLOAD_DURATION:10
#!arguments-desc=DOWNLOAD_URL: 下载测速URL\n
#!arguments-desc=UPLOAD_URL: 上传测速URL\n
#!arguments-desc=DOWNLOAD_URL_PROXY: 代理模式下载URL(未提供时使用download-url)\n
#!arguments-desc=UPLOAD_URL_PROXY: 代理模式上传URL(未提供时使用upload-url)\n
#!arguments-desc=DOWNLOAD_CONCURRENCY: 下载并发数(默认4)\n
#!arguments-desc=UPLOAD_CONCURRENCY: 上传并发数(默认4)\n
#!arguments-desc=DOWNLOAD_DURATION: 下载时长限制-秒(默认10)\n
#!arguments-desc=UPLOAD_SIZE: 上传大小限制-字节(默认1GB)\n
#!arguments-desc=UPLOAD_DURATION: 上传时长限制-秒(默认10)

[Testing]
download-url = {{{DOWNLOAD_URL}}}
upload-url = {{{UPLOAD_URL}}}
download-url-proxy = {{{DOWNLOAD_URL_PROXY}}}
upload-url-proxy = {{{UPLOAD_URL_PROXY}}}
download-concurrency = {{{DOWNLOAD_CONCURRENCY}}}
upload-concurrency = {{{UPLOAD_CONCURRENCY}}}
download-duration-limit = {{{DOWNLOAD_DURATION}}}
upload-size-limit = {{{UPLOAD_SIZE}}}
upload-duration-limit = {{{UPLOAD_DURATION}}}
