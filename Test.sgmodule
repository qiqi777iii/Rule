#!name=Network Speed Test
#!desc=网络测速配置模块 - 支持参数自定义
#!system=ios
#!arguments=DOWNLOAD_URL:https://speed.cloudflare.com/__down?bytes=100000000,UPLOAD_URL:https://speed.cloudflare.com/__up,DOWNLOAD_CONCURRENCY:4,UPLOAD_CONCURRENCY:4,DOWNLOAD_DURATION:10,UPLOAD_DURATION:10,UPLOAD_SIZE:1073741824
#!arguments-desc=DOWNLOAD_URL: 下载测速URL\nUPLOAD_URL: 上传测速URL\nDOWNLOAD_CONCURRENCY: 下载并发数(1-8)\nUPLOAD_CONCURRENCY: 上传并发数(1-8)\nDOWNLOAD_DURATION: 下载时长限制(秒)\nUPLOAD_DURATION: 上传时长限制(秒)\nUPLOAD_SIZE: 上传大小限制(字节)

[Testing]
download-url = {{{DOWNLOAD_URL}}}
upload-url = {{{UPLOAD_URL}}}
download-concurrency = {{{DOWNLOAD_CONCURRENCY}}}
upload-concurrency = {{{UPLOAD_CONCURRENCY}}}
download-duration-limit = {{{DOWNLOAD_DURATION}}}
upload-duration-limit = {{{UPLOAD_DURATION}}}
upload-size-limit = {{{UPLOAD_SIZE}}}
